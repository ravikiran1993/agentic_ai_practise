# Copy this file to ".env" and fill in real values.
# .env is gitignored so your secrets stay private.

# xAI (Grok) API key — powers the in-app data assistant.
# Get one at https://console.x.ai  (format: xai-...)
XAI_API_KEY=your-xai-key-here

# Optional: which Grok model to use (defaults to grok-2-latest).
# Set this to whatever model your xAI account supports, e.g. grok-3, grok-4.
# XAI_MODEL=grok-2-latest
