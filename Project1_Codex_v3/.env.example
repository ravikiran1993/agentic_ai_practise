# Primary provider: Google Gemini (free tier ~1,500 requests/day).
# Get a key at https://aistudio.google.com -> "Get API key".
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Optional fallback: Groq. Used automatically if Gemini errors (e.g. rate limit).
# Leave blank to run Gemini-only.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
