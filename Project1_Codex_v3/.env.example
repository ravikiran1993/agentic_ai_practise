# The assistant uses a fallback chain of free, OpenAI-compatible LLM providers.
# They are tried top to bottom; when one runs out of free quota the app rolls to
# the next automatically. Set as many or as few as you like (at least one).

# 1) Google Gemini — https://aistudio.google.com -> "Get API key"
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# 2) Groq — https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# 3) Cerebras — https://cloud.cerebras.ai (very generous free daily budget, fast)
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama-3.3-70b

# 4) OpenRouter — https://openrouter.ai/keys (use a ":free" model id)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# 5) Mistral — https://console.mistral.ai
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
